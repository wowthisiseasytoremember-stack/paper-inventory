generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Item {
  id                    String   @id @default(uuid())
  
  // State Machine
  status                String   @default("queued") // queued, processing_ocr, ocr_complete, processing_resize, resize_complete, processing_ai, complete, error
  processingLock        Boolean  @default(false)
  retryCount            Int      @default(0)
  watchdogLockedAt     DateTime?
  errorMessage          String?
  
  // Identification & Search
  title                 String
  guessedId             String
  rawOcr                String
  cleanedTranscription  String
  confidence            Float
  identifiedNames       Json
  historicalContext     String
  collectorSignificance String
  aiRawResponse         String?
  
  // Deduplication & Integrity
  originalHash          String
  contentHash           String   @unique // Post-strip/normalization
  originalFilename      String
  mimeType              String
  fileSize              Int
  ocrLanguage           String   @default("eng")
  tags                  Json     @default("[]")
  version               Int      @default(1)
  
  // Storage Paths
  originalImagePath     String
  resizedImagePath      String
  thumbnailPath         String
  
  // Observability & Metrics
  ocrDurationMs         Int?
  resizeDurationMs      Int?
  aiDurationMs          Int?
  totalProcessingMs     Int?
  
  // Timestamps
  createdAt             DateTime @default(now())
  processedAt           DateTime?
  deletedAt             DateTime? // Soft delete
}
